<!-- PROJECT 1 -->
<div class="project open" id="p1">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">01</span>
    <span class="proj-title">LED Blink</span>
    <div class="proj-tags">
      <span class="tag tag-output">output</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">GPIO digital output, setup() vs loop(), delay() timing — the foundation of all hardware projects.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">LED (+) Anode</td><td class="pin-esp">GPIO 2</td><td>Through 220Ω resistor</td></tr>
      <tr><td class="pin-comp">LED (–) Cathode</td><td class="pin-esp">GND</td><td>Short leg of LED</td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 1: LED Blink</span>
<span class="cm">// GPIO 2 is also the built-in LED on most ESP32 boards</span>

<span class="kw">const int</span> LED_PIN = <span class="nm">2</span>;

<span class="tp">void</span> <span class="fn">setup</span>() {
  pinMode(LED_PIN, OUTPUT);   <span class="cm">// set pin as output</span>
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  digitalWrite(LED_PIN, HIGH);  <span class="cm">// LED ON</span>
  delay(<span class="nm">1000</span>);                   <span class="cm">// wait 1 second</span>
  digitalWrite(LED_PIN, LOW);   <span class="cm">// LED OFF</span>
  delay(<span class="nm">1000</span>);                   <span class="cm">// wait 1 second</span>
}</pre>
    </div>
    <div class="tip">Try changing 1000 to 100 — the LED blinks 10x faster. Ask students: what happens at delay(10)?</div>
    <a class="wokwi-link" href="https://wokwi.com/projects/new/esp32" target="_blank">↗ Open in Wokwi</a>
  </div>
</div>

<!-- PROJECT 2 -->
<div class="project" id="p2">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">02</span>
    <span class="proj-title">Push Button + LED</span>
    <div class="proj-tags">
      <span class="tag tag-output">output</span>
      <span class="tag tag-logic">logic</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">Digital input reading, pull-up resistors, if-else logic — responding to real-world input.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">LED Anode (+)</td><td class="pin-esp">GPIO 2</td><td>Through 220Ω resistor</td></tr>
      <tr><td class="pin-comp">LED Cathode (–)</td><td class="pin-esp">GND</td><td></td></tr>
      <tr><td class="pin-comp">Button Pin 1</td><td class="pin-esp">GPIO 4</td><td>Any leg on one side</td></tr>
      <tr><td class="pin-comp">Button Pin 2</td><td class="pin-esp">GND</td><td>Other leg</td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 2: Push Button controls LED</span>
<span class="cm">// INPUT_PULLUP uses ESP32's internal resistor — no external resistor needed</span>

<span class="kw">const int</span> LED_PIN    = <span class="nm">2</span>;
<span class="kw">const int</span> BUTTON_PIN = <span class="nm">4</span>;

<span class="tp">void</span> <span class="fn">setup</span>() {
  pinMode(LED_PIN,    OUTPUT);
  pinMode(BUTTON_PIN, INPUT_PULLUP); <span class="cm">// internal pull-up: HIGH when not pressed</span>
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="kw">int</span> btnState = digitalRead(BUTTON_PIN);

  <span class="kw">if</span> (btnState == LOW) {    <span class="cm">// LOW = button pressed (pulled to GND)</span>
    digitalWrite(LED_PIN, HIGH);
  } <span class="kw">else</span> {
    digitalWrite(LED_PIN, LOW);
  }
}</pre>
    </div>
    <div class="tip">INPUT_PULLUP inverts logic: LOW means pressed. Ask students why this is and what a pull-down resistor does differently.</div>
  </div>
</div>

<!-- PROJECT 3 -->
<div class="project" id="p3">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">03</span>
    <span class="proj-title">Potentiometer + Serial Monitor</span>
    <div class="proj-tags">
      <span class="tag tag-sensor">sensor</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">Analog input, ADC (Analog-to-Digital Converter), Serial.print() for debugging — reading variable voltages.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">Potentiometer Left</td><td class="pin-esp">3.3V</td><td>Power pin</td></tr>
      <tr><td class="pin-comp">Potentiometer Middle (Wiper)</td><td class="pin-esp">GPIO 34</td><td>Analog input pin</td></tr>
      <tr><td class="pin-comp">Potentiometer Right</td><td class="pin-esp">GND</td><td>Ground pin</td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 3: Potentiometer value on Serial Monitor</span>
<span class="cm">// ESP32 ADC is 12-bit: values range from 0 to 4095</span>

<span class="kw">const int</span> POT_PIN = <span class="nm">34</span>; <span class="cm">// GPIO34 is input-only, great for analog</span>

<span class="tp">void</span> <span class="fn">setup</span>() {
  Serial.begin(<span class="nm">115200</span>);  <span class="cm">// start serial communication</span>
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="kw">int</span> rawValue = analogRead(POT_PIN);   <span class="cm">// 0 to 4095</span>
  <span class="kw">int</span> percent  = map(rawValue, <span class="nm">0</span>, <span class="nm">4095</span>, <span class="nm">0</span>, <span class="nm">100</span>); <span class="cm">// convert to 0-100%</span>

  Serial.print(<span class="st">"Raw: "</span>);
  Serial.print(rawValue);
  Serial.print(<span class="st">"  |  Percent: "</span>);
  Serial.print(percent);
  Serial.println(<span class="st">"%"</span>);

  delay(<span class="nm">300</span>);  <span class="cm">// slow down output</span>
}</pre>
    </div>
    <div class="tip">Open Wokwi's Serial Monitor (bottom panel) and turn the pot. map() is a very useful function — explain how it scales ranges.</div>
  </div>
</div>

<!-- PROJECT 4 -->
<div class="project" id="p4">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">04</span>
    <span class="proj-title">PWM LED Dimmer (Fade)</span>
    <div class="proj-tags">
      <span class="tag tag-output">output</span>
      <span class="tag tag-logic">logic</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">PWM (Pulse Width Modulation), duty cycle, ESP32's LEDC peripheral, smooth animation with for loops.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">LED Anode (+)</td><td class="pin-esp">GPIO 16</td><td>Through 220Ω resistor</td></tr>
      <tr><td class="pin-comp">LED Cathode (–)</td><td class="pin-esp">GND</td><td></td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 4: PWM LED Fade using ESP32 LEDC</span>
<span class="cm">// ESP32 uses ledcWrite instead of analogWrite</span>

<span class="kw">const int</span> LED_PIN  = <span class="nm">16</span>;
<span class="kw">const int</span> CHANNEL  = <span class="nm">0</span>;   <span class="cm">// PWM channel (0-15)</span>
<span class="kw">const int</span> FREQ     = <span class="nm">5000</span>;<span class="cm">// 5 kHz frequency</span>
<span class="kw">const int</span> RESOLUTION = <span class="nm">8</span>; <span class="cm">// 8-bit = values 0-255</span>

<span class="tp">void</span> <span class="fn">setup</span>() {
  ledcSetup(CHANNEL, FREQ, RESOLUTION); <span class="cm">// configure PWM</span>
  ledcAttachPin(LED_PIN, CHANNEL);      <span class="cm">// attach LED pin to channel</span>
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="cm">// Fade in: 0 → 255</span>
  <span class="kw">for</span> (<span class="kw">int</span> brightness = <span class="nm">0</span>; brightness <= <span class="nm">255</span>; brightness++) {
    ledcWrite(CHANNEL, brightness);
    delay(<span class="nm">8</span>);
  }
  <span class="cm">// Fade out: 255 → 0</span>
  <span class="kw">for</span> (<span class="kw">int</span> brightness = <span class="nm">255</span>; brightness >= <span class="nm">0</span>; brightness--) {
    ledcWrite(CHANNEL, brightness);
    delay(<span class="nm">8</span>);
  }
}</pre>
    </div>
    <div class="tip">Ask students: if RESOLUTION is 8-bit, why do values go 0–255? (2^8 = 256 levels). Change delay(8) to delay(2) for a faster pulse effect.</div>
  </div>
</div>

<!-- PROJECT 5 -->
<div class="project" id="p5">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">05</span>
    <span class="proj-title">Temperature & Humidity (DHT11)</span>
    <div class="proj-tags">
      <span class="tag tag-sensor">sensor</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">Sensor libraries, single-wire data protocol, reading structured sensor data (temperature + humidity together).</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">DHT11 VCC</td><td class="pin-esp">3.3V</td><td>Power</td></tr>
      <tr><td class="pin-comp">DHT11 DATA</td><td class="pin-esp">GPIO 4</td><td>Through 10kΩ pull-up to 3.3V</td></tr>
      <tr><td class="pin-comp">DHT11 GND</td><td class="pin-esp">GND</td><td></td></tr>
    </table>

    <p class="section-title">Library needed</p>
    <p style="font-size:12px;color:#9ca3af;margin-bottom:1rem;font-family:'JetBrains Mono',monospace;">In Wokwi: automatically available. In Arduino IDE: install "DHT sensor library" by Adafruit.</p>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 5: DHT11 Temperature & Humidity</span>
<span class="cm">// Library: DHT sensor library by Adafruit</span>

#include &lt;DHT.h&gt;

<span class="kw">const int</span> DHT_PIN  = <span class="nm">4</span>;
<span class="kw">const int</span> DHT_TYPE = DHT11;

DHT dht(DHT_PIN, DHT_TYPE);

<span class="tp">void</span> <span class="fn">setup</span>() {
  Serial.begin(<span class="nm">115200</span>);
  dht.begin();
  Serial.println(<span class="st">"DHT11 Ready!"</span>);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  delay(<span class="nm">2000</span>);  <span class="cm">// DHT11 needs 2s between readings</span>

  <span class="kw">float</span> humidity    = dht.readHumidity();
  <span class="kw">float</span> temperature = dht.readTemperature(); <span class="cm">// Celsius</span>

  <span class="kw">if</span> (isnan(humidity) || isnan(temperature)) {
    Serial.println(<span class="st">"Sensor read error!"</span>);
    <span class="kw">return</span>;
  }

  Serial.print(<span class="st">"Temp: "</span>);
  Serial.print(temperature);
  Serial.print(<span class="st">" °C  |  Humidity: "</span>);
  Serial.print(humidity);
  Serial.println(<span class="st">"%"</span>);
}</pre>
    </div>
