      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 10: LDR Auto LED — LED turns ON in the dark</span>
<span class="cm">// Lower LDR value = more light. Higher value = darker.</span>

<span class="kw">const int</span> LDR_PIN   = <span class="nm">34</span>;
<span class="kw">const int</span> LED_PIN   = <span class="nm">2</span>;
<span class="kw">const int</span> THRESHOLD = <span class="nm">2000</span>; <span class="cm">// adjust based on your environment</span>

<span class="tp">void</span> <span class="fn">setup</span>() {
  Serial.begin(<span class="nm">115200</span>);
  pinMode(LED_PIN, OUTPUT);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="kw">int</span> ldrValue = analogRead(LDR_PIN);  <span class="cm">// 0–4095</span>

  Serial.print(<span class="st">"Light level: "</span>);
  Serial.print(ldrValue);

  <span class="kw">if</span> (ldrValue &gt; THRESHOLD) {
    <span class="cm">// It's dark — LDR resistance high, voltage high</span>
    digitalWrite(LED_PIN, HIGH);
    Serial.println(<span class="st">"  → DARK, LED ON"</span>);
  } <span class="kw">else</span> {
    <span class="cm">// It's bright</span>
    digitalWrite(LED_PIN, LOW);
    Serial.println(<span class="st">"  → BRIGHT, LED OFF"</span>);
  }

  delay(<span class="nm">500</span>);
}</pre>
    </div>
    <div class="tip">Run it first and read the raw LDR value in serial — then set THRESHOLD to a value between your bright and dark readings. In Wokwi, slide the LDR light slider to simulate day/night.</div>
