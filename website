      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">LDR Pin 1</td><td class="pin-esp">3.3V</td><td>One leg to power</td></tr>
      <tr><td class="pin-comp">LDR Pin 2</td><td class="pin-esp">GPIO 34</td><td>Also connect 10kΩ from this pin to GND</td></tr>
      <tr><td class="pin-comp">10kΩ Resistor</td><td class="pin-esp">GPIO 34 → GND</td><td>Forms voltage divider with LDR</td></tr>
      <tr><td class="pin-comp">LED Anode (+)</td><td class="pin-esp">GPIO 2</td><td>Through 220Ω resistor</td></tr>
