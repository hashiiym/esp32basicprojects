      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 9: PIR Motion Detector with LED Alert</span>
<span class="cm">// PIR output is HIGH when motion detected, LOW otherwise</span>

<span class="kw">const int</span> PIR_PIN = <span class="nm">13</span>;
<span class="kw">const int</span> LED_PIN = <span class="nm">2</span>;

<span class="tp">void</span> <span class="fn">setup</span>() {
  Serial.begin(<span class="nm">115200</span>);
  pinMode(PIR_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  Serial.println(<span class="st">"PIR warming up... wait 30 seconds"</span>);
  delay(<span class="nm">5000</span>); <span class="cm">// In real life PIR needs 30s warm-up; short for demo</span>
  Serial.println(<span class="st">"Ready! Watching for motion..."</span>);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="kw">int</span> motion = digitalRead(PIR_PIN);

  <span class="kw">if</span> (motion == HIGH) {
    digitalWrite(LED_PIN, HIGH);
    Serial.println(<span class="st">"Motion DETECTED!"</span>);
    delay(<span class="nm">2000</span>);  <span class="cm">// keep LED on for 2 seconds</span>
  } <span class="kw">else</span> {
    digitalWrite(LED_PIN, LOW);
    Serial.println(<span class="st">"No motion."</span>);
  }

  delay(<span class="nm">200</span>);
}</pre>
    </div>
    <div class="tip">In Wokwi, click the PIR sensor during simulation to toggle motion ON/OFF. Add a buzzer to make it a real intruder alarm!</div>
