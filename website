<!-- PROJECT 8 -->
<div class="project" id="p8">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">08</span>
    <span class="proj-title">Buzzer Melody Player</span>
    <div class="proj-tags">
      <span class="tag tag-output">output</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">PWM for audio, frequency = musical pitch, storing data in arrays, looping through arrays with for loops.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">Buzzer (+)</td><td class="pin-esp">GPIO 18</td><td>Passive buzzer only (not active)</td></tr>
      <tr><td class="pin-comp">Buzzer (–)</td><td class="pin-esp">GND</td><td></td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 8: Buzzer plays a simple melody</span>
<span class="cm">// Using ESP32 LEDC for tone generation</span>

<span class="kw">const int</span> BUZZER_PIN = <span class="nm">18</span>;
<span class="kw">const int</span> CHANNEL    = <span class="nm">0</span>;

<span class="cm">// Note frequencies (Hz)</span>
<span class="kw">const int</span> NOTE_C4 = <span class="nm">262</span>;
<span class="kw">const int</span> NOTE_D4 = <span class="nm">294</span>;
<span class="kw">const int</span> NOTE_E4 = <span class="nm">330</span>;
<span class="kw">const int</span> NOTE_F4 = <span class="nm">349</span>;
<span class="kw">const int</span> NOTE_G4 = <span class="nm">392</span>;
<span class="kw">const int</span> NOTE_A4 = <span class="nm">440</span>;
<span class="kw">const int</span> REST    = <span class="nm">0</span>;

<span class="cm">// Melody: Twinkle Twinkle Little Star</span>
<span class="kw">int</span> melody[] = {
  NOTE_C4, NOTE_C4, NOTE_G4, NOTE_G4,
  NOTE_A4, NOTE_A4, NOTE_G4, REST,
  NOTE_F4, NOTE_F4, NOTE_E4, NOTE_E4,
  NOTE_D4, NOTE_D4, NOTE_C4, REST
};

<span class="kw">int</span> durations[] = {
  <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">400</span>,
  <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">800</span>, <span class="nm">400</span>,
  <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">400</span>,
  <span class="nm">400</span>, <span class="nm">400</span>, <span class="nm">800</span>, <span class="nm">400</span>
};

<span class="kw">int</span> noteCount = <span class="kw">sizeof</span>(melody) / <span class="kw">sizeof</span>(melody[<span class="nm">0</span>]);

<span class="tp">void</span> <span class="fn">playTone</span>(<span class="kw">int</span> freq, <span class="kw">int</span> dur) {
  <span class="kw">if</span> (freq == REST) {
    ledcWriteTone(CHANNEL, <span class="nm">0</span>);
  } <span class="kw">else</span> {
    ledcWriteTone(CHANNEL, freq);
  }
  delay(dur);
  ledcWriteTone(CHANNEL, <span class="nm">0</span>);
  delay(<span class="nm">50</span>); <span class="cm">// short pause between notes</span>
}

<span class="tp">void</span> <span class="fn">setup</span>() {
  ledcSetup(CHANNEL, <span class="nm">2000</span>, <span class="nm">8</span>);
  ledcAttachPin(BUZZER_PIN, CHANNEL);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="kw">for</span> (<span class="kw">int</span> i = <span class="nm">0</span>; i &lt; noteCount; i++) {
    playTone(melody[i], durations[i]);
  }
  delay(<span class="nm">2000</span>); <span class="cm">// pause before repeating</span>
}</pre>
    </div>
    <div class="tip">Explain: higher Hz = higher pitch. 440 Hz is concert A. Students can add their own notes to the arrays to compose a different song!</div>
  </div>
</div>

