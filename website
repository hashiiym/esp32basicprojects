<!-- PROJECT 6 -->
<div class="project" id="p6">
  <div class="project-header" onclick="toggle(this)">
    <span class="proj-num">06</span>
    <span class="proj-title">Ultrasonic Distance Meter (HC-SR04)</span>
    <div class="proj-tags">
      <span class="tag tag-sensor">sensor</span>
    </div>
    <span class="chevron">▾</span>
  </div>
  <div class="project-body">
    <p class="section-title">What students learn</p>
    <p style="font-size:13px;color:#9ca3af;margin-bottom:1rem;">Trigger/echo pulse timing, pulseIn(), speed of sound, converting microseconds to centimeters.</p>

    <p class="section-title">Wiring connections</p>
    <table class="wiring-table">
      <tr><th>Component Pin</th><th>ESP32 Pin</th><th>Notes</th></tr>
      <tr><td class="pin-comp">HC-SR04 VCC</td><td class="pin-esp">5V (VIN)</td><td>HC-SR04 needs 5V, not 3.3V</td></tr>
      <tr><td class="pin-comp">HC-SR04 TRIG</td><td class="pin-esp">GPIO 5</td><td>Trigger pin</td></tr>
      <tr><td class="pin-comp">HC-SR04 ECHO</td><td class="pin-esp">GPIO 18</td><td>Echo pin</td></tr>
      <tr><td class="pin-comp">HC-SR04 GND</td><td class="pin-esp">GND</td><td></td></tr>
    </table>

    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 6: Ultrasonic Distance Meter</span>
<span class="cm">// Formula: distance (cm) = duration × 0.034 / 2</span>

<span class="kw">const int</span> TRIG_PIN = <span class="nm">5</span>;
<span class="kw">const int</span> ECHO_PIN = <span class="nm">18</span>;

<span class="tp">void</span> <span class="fn">setup</span>() {
  Serial.begin(<span class="nm">115200</span>);
  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="cm">// Send 10µs trigger pulse</span>
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(<span class="nm">2</span>);
  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(<span class="nm">10</span>);
  digitalWrite(TRIG_PIN, LOW);

  <span class="cm">// Measure echo duration in microseconds</span>
  <span class="kw">long</span> duration = pulseIn(ECHO_PIN, HIGH);

  <span class="cm">// Convert to centimeters</span>
  <span class="kw">float</span> distance = duration * <span class="nm">0.034</span> / <span class="nm">2</span>;

  Serial.print(<span class="st">"Distance: "</span>);
  Serial.print(distance);
  Serial.println(<span class="st">" cm"</span>);

  delay(<span class="nm">500</span>);
}</pre>
    </div>
    <div class="tip">In Wokwi, drag the object in front of the HC-SR04 sensor to change the simulated distance. Ask students to explain why we divide by 2 (sound travels to object AND back).</div>
  </div>
</div>

<!-- PROJECT 7 -->
<div class="project" id="p7">
  <div class="project-header" onclick="toggle(this)">
