    <p class="section-title">Arduino code</p>
    <div class="code-wrap">
      <div class="code-header"><span class="code-lang">Arduino / C++</span><button class="copy-btn" onclick="copyCode(this)">copy</button></div>
      <pre><span class="cm">// Project 7: Traffic Light Sequence</span>

<span class="kw">const int</span> RED_PIN    = <span class="nm">2</span>;
<span class="kw">const int</span> YELLOW_PIN = <span class="nm">4</span>;
<span class="kw">const int</span> GREEN_PIN  = <span class="nm">5</span>;

<span class="tp">void</span> <span class="fn">allOff</span>() {
  digitalWrite(RED_PIN,    LOW);
  digitalWrite(YELLOW_PIN, LOW);
  digitalWrite(GREEN_PIN,  LOW);
}

<span class="tp">void</span> <span class="fn">setup</span>() {
  pinMode(RED_PIN,    OUTPUT);
  pinMode(YELLOW_PIN, OUTPUT);
  pinMode(GREEN_PIN,  OUTPUT);
}

<span class="tp">void</span> <span class="fn">loop</span>() {
  <span class="cm">// RED — Stop</span>
  allOff();
  digitalWrite(RED_PIN, HIGH);
  delay(<span class="nm">4000</span>);

  <span class="cm">// RED + YELLOW — Get ready</span>
  digitalWrite(YELLOW_PIN, HIGH);
  delay(<span class="nm">1000</span>);

  <span class="cm">// GREEN — Go</span>
  allOff();
  digitalWrite(GREEN_PIN, HIGH);
  delay(<span class="nm">4000</span>);

  <span class="cm">// YELLOW — Slow down</span>
  allOff();
  digitalWrite(YELLOW_PIN, HIGH);
  delay(<span class="nm">1500</span>);
}</pre>
    </div>
